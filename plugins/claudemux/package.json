{
  "name": "@excitedjs/tm",
  "version": "2.3.1",
  "description": "Multi-repo AI orchestrator CLI — spawn, message, and wait on Claude/Codex teammates across sibling repos.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/excitedjs/claudemux.git",
    "directory": "plugins/claudemux"
  },
  "engines": {
    "node": ">=22.7.0"
  },
  "imports": {
    "#ws": "./third_party/ws/wrapper.mjs"
  },
  "bin": {
    "tm": "./dist/tm.mjs"
  },
  "files": [
    "bin/tm",
    "dist/"
  ],
  "scripts": {
    "build:npm": "node scripts/build-npm.mjs",
    "prepack": "node scripts/build-npm.mjs",
    "changeset": "changeset",
    "version-packages": "changeset version && node scripts/sync-plugin-version.mjs",
    "version-ga": "changeset pre exit && changeset version && node scripts/sync-plugin-version.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint:dead-code": "node scripts/check-dead-code.mjs"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "esbuild": "0.25.12",
    "knip": "5.80.2",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  }
}
